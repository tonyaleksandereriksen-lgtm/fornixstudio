+}
diff --git a/src/producer/orchestrator.ts b/src/producer/orchestrator.ts
new file mode 100644
index 0000000..4444444
--- /dev/null
+++ b/src/producer/orchestrator.ts
@@ -0,0 +1,92 @@
+import { hasCapability, summarizeCapabilities } from "../daw/capabilities";
+import type { DawAdapter } from "../daw/types";
+import type { ProducerIntentInput, ProducerPlan } from "./intents";
+
+export async function buildProducerPlan(
+  adapter: DawAdapter,
+  input: ProducerIntentInput,
+): Promise<ProducerPlan> {
+  const [capabilities, session] = await Promise.all([
+    adapter.getCapabilities(),
+    adapter.getSessionSnapshot(),
+  ]);
+
+  const capabilityWarnings = summarizeCapabilities(capabilities).length
+    ? []
+    : ["No DAW capabilities were reported by the active adapter."];
+
+  if (input.id === "critique-drop") {
+    const target =
+      input.targetSectionId ??
+      session.selectedSectionId ??
+      session.sections.find((section) =>
+        /drop|chorus|hook/i.test(section.name),
+      )?.id;
+
+    return {
+      title: "Critique this drop",
+      summary: target
+        ? `Review section ${target} with a preview-first critique plan.`
+        : "No target section was detected. Fall back to a whole-song critique.",
+      warnings: [
+        ...capabilityWarnings,
+        ...(!hasCapability(capabilities, "session.read")
+          ? ["Session read is not proven. Use a conservative, non-destructive critique flow."]
+          : []),
+      ],
+      suggestions: [
+        {
+          id: "drop-impact",
+          title: "Check impact and contrast",
+          rationale:
+            "Compare density, low-end handoff, and release against the pre-drop transition.",
+          confidence: "high",
+        },
+        {
+          id: "drop-hook",
+          title: "Audit hook clarity",
+          rationale:
+            "Look for lead masking, over-stacked layers, and weak rhythmic anchors.",
+          confidence: "medium",
+        },
+      ],
+    };
+  }
+
+  return {
+    title: "Prepare for mastering",
+    summary: "Create a conservative mastering-prep checklist and previewable actions.",
+    warnings: [
+      ...capabilityWarnings,
+      ...(!hasCapability(capabilities, "session.read")
+        ? ["Session read is not proven. Use export/package guidance instead of live edits."]
+        : []),
+    ],
+    suggestions: [
+      {
+        id: "master-headroom",
+        title: "Verify headroom and clipping risk",
+        rationale:
+          "Check for limiter dependency, master bus overload, and final export headroom.",
+        confidence: "high",
+      },
+      {
+        id: "master-export",
+        title: "Prepare handoff/export settings",
+        rationale:
+          "Generate a clean print checklist, tail policy, and version naming plan.",
+        confidence: "high",
+      },
+    ],
+  };
+}
