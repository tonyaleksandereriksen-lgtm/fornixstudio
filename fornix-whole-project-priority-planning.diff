+    energyProfile: metadata.energyProfile,
+    targetBars: metadata.targetBars,
+    creativeBrief: metadata.creativeBrief,
+    mixConcerns: [...metadata.mixConcerns],
+    signatureHooks: [...metadata.signatureHooks],
+    mood: metadata.mood,
+    focus: metadata.focus,
+    concerns: metadata.concerns ? [...metadata.concerns] : undefined,
+    substyle: metadata.substyle,
+    kickStyle: metadata.kickStyle,
+    antiClimaxStyle: metadata.antiClimaxStyle,
+    arrangementFocus: metadata.arrangementFocus,
