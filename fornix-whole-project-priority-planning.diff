+
+function mergeInputOverMetadata(
+  metadata: ProductionPackageMetadata,
+  updates: Partial<Omit<RegeneratePackageSectionInput, "packagePath" | "section" | "trackSlug" | "outputDir">>,
+  outputDir: string,
